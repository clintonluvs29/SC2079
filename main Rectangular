def transform_commands(commands):
    transformed_commands = []
    
    for cmd in commands:
        if cmd == ('RIGHT', 90):
            # Replace RIGHT 90 with (RIGHT 45, BACKWARD_LEFT 45)
            transformed_commands.extend([('RIGHT', 45), ('BACKLEFT', 45)])
        elif cmd == ('LEFT', 90):
            # Replace LEFT 90 with (LEFT 45, BACKWARD_RIGHT 45)
            transformed_commands.extend([('LEFT', 45), ('BACKRIGHT', 45)])
        else:
            # Otherwise, keep the original command
            transformed_commands.append(cmd)
    
    return transformed_commands

